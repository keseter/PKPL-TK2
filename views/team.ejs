<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= groupName %> - Team</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body style="--bg-color:<%= theme.bgColor %>;--text-color:<%= theme.textColor %>;--card-color:<%= theme.cardColor %>;--accent-color:<%= theme.accentColor %>;--font-family:<%= theme.fontFamily %>;">
  <%- include('partials/header') %>
  <%- include('partials/toast') %>

  <main class="container page-stack">
    <section class="card">
      <div class="section-head">
        <h1>Team</h1>
        <span class="muted">Public profile</span>
      </div>

      <div class="team-grid">
        <% members.forEach((member) => { %>
          <article class="team-card">
            <img src="<%= member.photo %>" alt="<%= member.name %>" />
            <h3><%= member.name %></h3>
            <p class="muted"><%= member.nim %></p>
            <p class="role-chip"><%= member.role %></p>
            <p><%= member.bio %></p>
          </article>
        <% }) %>
      </div>
    </section>
  </main>
</body>
</html>
