<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= groupName %> - Account</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body style="--bg-color:<%= theme.bgColor %>;--text-color:<%= theme.textColor %>;--card-color:<%= theme.cardColor %>;--accent-color:<%= theme.accentColor %>;--font-family:<%= theme.fontFamily %>;">
  <%- include('partials/header') %>
  <%- include('partials/toast') %>

  <main class="container page-stack">
    <section class="card account-card">
      <div class="section-head">
        <h1>Account</h1>
      </div>

      <% if (auth.isLoggedIn) { %>
        <div class="account-state">
          <% if (auth.user.photo) { %>
            <img src="<%= auth.user.photo %>" alt="<%= auth.user.name %>" class="avatar" />
          <% } %>
          <div>
            <h3><%= auth.user.name %></h3>
            <p class="muted"><%= auth.user.email %></p>
            <p class="role-chip"><%= auth.isAdmin ? 'Anggota Kelompok (Admin Tampilan)' : 'Pengguna Biasa (View Only)' %></p>
          </div>
        </div>

        <ul class="cap-list">
          <li>Semua akun login Google: checkout + review.</li>
          <li>Akun anggota kelompok: akses halaman admin untuk ubah warna/font website.</li>
        </ul>

        <form action="/logout" method="post">
          <button class="btn btn-light" type="submit">Logout</button>
        </form>
      <% } else { %>
        <p class="muted">Masuk dengan Google untuk membuat akun otomatis dan menggunakan fitur personal.</p>
        <% if (googleOAuthEnabled) { %>
          <a class="btn btn-primary" href="/auth/google">Masuk dengan Google</a>
        <% } else { %>
          <p class="muted">OAuth Google belum aktif di server.</p>
        <% } %>
      <% } %>
    </section>
  </main>
</body>
</html>
