<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= groupName %></title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    :root {
      --bg-color: <%= theme.bgColor %>;
      --text-color: <%= theme.textColor %>;
      --card-color: <%= theme.cardColor %>;
      --font-family: <%= theme.fontFamily %>;
    }
  </style>
</head>
<body>
  <header class="navbar">
    <div>
      <h1><%= groupName %></h1>
      <p><%= courseName %></p>
    </div>

    <div class="auth-box">
      <% if (isLoggedIn && user) { %>
        <span>Halo, <%= user.name %></span>
      <% } else { %>
        <button class="login-btn" disabled>Login Google (akan ditambahkan)</button>
      <% } %>
    </div>
  </header>

  <main class="container">
    <section class="intro">
      <h2>Biodata Kelompok</h2>
      <p>
        Halaman ini menampilkan biodata anggota kelompok dan dapat diakses tanpa login.
      </p>
    </section>

    <section class="member-grid">
      <% members.forEach(member => { %>
        <div class="card">
          <img src="<%= member.photo %>" alt="<%= member.name %>" class="avatar" />
          <h3><%= member.name %></h3>
          <p><strong>NIM:</strong> <%= member.nim %></p>
          <p><strong>Role:</strong> <%= member.role %></p>
          <p><%= member.bio %></p>
        </div>
      <% }) %>
    </section>
  </main>
</body>
</html>