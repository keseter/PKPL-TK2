<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= groupName %> - Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body style="--bg-color:<%= theme.bgColor %>;--text-color:<%= theme.textColor %>;--card-color:<%= theme.cardColor %>;--accent-color:<%= theme.accentColor %>;--font-family:<%= theme.fontFamily %>;">
  <%- include('partials/header') %>
  <%- include('partials/toast') %>

  <main class="container page-stack">
    <section class="card">
      <div class="section-head">
        <h1>Admin Panel</h1>
        <span class="muted">Hanya akun anggota kelompok</span>
      </div>

      <form action="/admin/theme" method="post" class="theme-grid">
        <label>
          Background
          <input type="color" name="bgColor" value="<%= theme.bgColor %>" required />
        </label>
        <label>
          Text
          <input type="color" name="textColor" value="<%= theme.textColor %>" required />
        </label>
        <label>
          Card
          <input type="color" name="cardColor" value="<%= theme.cardColor %>" required />
        </label>
        <label>
          Accent
          <input type="color" name="accentColor" value="<%= theme.accentColor %>" required />
        </label>
        <label>
          Font
          <select name="fontKey" required>
            <% fontChoices.forEach((fontKey) => { %>
              <option value="<%= fontKey %>" <%= theme.fontKey === fontKey ? 'selected' : '' %>>
                <%= fontKey.replace('-', ' ').toUpperCase() %>
              </option>
            <% }) %>
          </select>
        </label>
        <button class="btn btn-primary" type="submit">Simpan Tampilan</button>
      </form>

      <hr class="divider" />

      <p class="muted">Stock dan moderasi review dikelola langsung dari halaman detail masing-masing produk.</p>
      <a class="btn btn-light" href="/products">Buka Daftar Produk</a>
    </section>
  </main>
</body>
</html>
